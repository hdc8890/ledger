# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
CLERK_WEBHOOK_SECRET=whsec_...

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Encryption (libsodium) — base64-encoded 32-byte key
ENCRYPTION_KEY=

# AI providers — see apps/web/src/ai/provider.ts
#
# Per-role provider switch. Supported chat providers:
#   anthropic     — direct API (ANTHROPIC_API_KEY)
#   openai        — direct API (OPENAI_API_KEY)
#   github-models — OpenAI-compatible gateway, auth via GITHUB_TOKEN (PAT
#                   with `models:read` scope). No LLM API key needed.
#   opencode-go   — OpenCode Go server (OpenAI-compatible); local or remote.
#
# Defaults preserve pre-refactor behavior (Claude Sonnet chat, gpt-4o-mini
# enrichment, text-embedding-3-small embeddings on OpenAI).
LLM_CHAT_PROVIDER=anthropic
LLM_CHAT_MODEL=claude-sonnet-4-5
LLM_TITLE_PROVIDER=anthropic
LLM_TITLE_MODEL=claude-haiku-4-5
LLM_ENRICHMENT_PROVIDER=openai
LLM_ENRICHMENT_MODEL=gpt-4o-mini
# Embedding provider must serve a 1536-dim model (pgvector schema is locked).
LLM_EMBEDDING_PROVIDER=openai
LLM_EMBEDDING_MODEL=text-embedding-3-small

# Direct provider keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# GitHub Models (OpenAI-compatible; auth via GITHUB_TOKEN)
GITHUB_TOKEN=
GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference

# OpenCode Go server (OpenAI-compatible; default port 4000)
# OPENCODE_GO_ENDPOINT=http://127.0.0.1:4000/v1
# OPENCODE_GO_API_KEY=opencode
